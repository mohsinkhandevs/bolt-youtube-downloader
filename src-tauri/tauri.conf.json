{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bolt",
  "version": "1.0.0",
  "identifier": "com.bolt.downloader",
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Bolt Downloader",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/*"
    ]
  }
}